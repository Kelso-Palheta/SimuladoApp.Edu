rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Professores: leem/escrevem próprio documento
    match /professores/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Correções de redação: leitura pública (aluno), escrita pelo professor dono
      match /correcoes/{corrId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Atividades: leitura pública, escrita autenticada
    match /atividades/{activityId} {
      allow read: if true;
      allow write: if request.auth != null && (
        !exists(/databases/$(database)/documents/atividades/$(activityId)) ||
        resource.data.professorId == request.auth.uid
      );

      match /tokens/{alunoId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Entregas: criação/leitura pública, modificação autenticada
    match /entregas/{entregaId} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Login do aluno: leitura pública, vínculos gerenciados por professores
    match /alunoLogin/{loginKey} {
      allow read: if true;
      allow write: if request.auth != null;

      match /vinculos/{profId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Notas do aluno: leitura pública
    match /notasAluno/{recordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regra padrão: negar tudo não explicitado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
